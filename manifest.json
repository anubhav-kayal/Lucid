{
  "manifest_version": 3,
  "name": "Lucid",
  "version": "0.1.0",
  "description": "A reading-simplification extension that strips clutter and simplifies text.",
  "permissions": [
    "storage",
    "offscreen",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "Lucid"
  },
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/readability.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles/reader-view.css",
        "lib/mermaid.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
